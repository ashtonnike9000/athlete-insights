generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Athlete {
  id            String          @id @default(cuid())
  name          String
  eventFocus    String          @default("")
  shoeSize      String          @default("")
  weeklyVolume  String          @default("")
  coach         String          @default("")
  teamGroup     String          @default("")
  photoUrl      String          @default("")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  visits        Visit[]
  footwearNotes FootwearNote[]
  quotes        Quote[]
  protocols     Protocol[]
}

model Visit {
  id            String          @id @default(cuid())
  athleteId     String
  visitDate     DateTime
  location      String          @default("")
  interviewer   String          @default("")
  sessionNotes  String          @default("")
  createdAt     DateTime        @default(now())
  athlete       Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  footwearNotes FootwearNote[]
  quotes        Quote[]
  protocols     Protocol[]
}

model FootwearNote {
  id        String   @id @default(cuid())
  athleteId String
  visitId   String
  shoeName  String
  useCase   String   @default("")
  frequency String   @default("")
  sentiment String   @default("positive")
  notes     String   @default("")
  createdAt DateTime @default(now())
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

model Quote {
  id        String   @id @default(cuid())
  athleteId String
  visitId   String
  text      String
  topic     String   @default("general")
  context   String   @default("")
  createdAt DateTime @default(now())
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

model Protocol {
  id          String   @id @default(cuid())
  athleteId   String
  visitId     String
  category    String
  description String   @default("")
  createdAt   DateTime @default(now())
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  visit       Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

model Theme {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  athleteNames String  @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
